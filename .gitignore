# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Build and packaging
build/
dist/
site/
.eggs/
*.egg
*.egg-info/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# IDEs and editors
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs and local runtime noise
*.log
*.pid
*.tmp

# Local launcher/install artifacts
.local/

# Project-generated cache content
codejump/data/index_cache/*
!codejump/data/index_cache/.gitkeep

# Keep tracked default config/data files, ignore accidental local copies/backups
codejump/config/*.bak
codejump/config/*.local.json
codejump/data/*.bak

